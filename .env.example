# --- Required ---

# 32 bytes base64. Generate with: openssl rand -base64 32
MASTER_KEY=

# 32+ bytes random for signing session cookies. openssl rand -base64 48
SESSION_SECRET=

# --- Optional ---

# Path to data directory (sqlite + blobs). Default ./data
DATA_DIR=./data

# API HTTP port
API_PORT=3001

# Comma-separated origins allowed by CORS (frontend URL)
CORS_ORIGIN=http://localhost:3000

# Session DEK cache TTL (idle minutes / hard cap minutes)
KEY_CACHE_IDLE_MIN=30
KEY_CACHE_HARD_MIN=1440

# Set to "true" only when the app is served behind HTTPS. With Secure=true
# over plain HTTP the browser sets the cookie but refuses to send it back,
# which manifests as "I logged in and the page bounces back to /login".
COOKIE_SECURE=false

# Snapshot worker concurrency
SNAPSHOT_CONCURRENCY=2

# OAuth — Google Drive
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/cloud/connect/gdrive/callback

# OAuth — Microsoft (OneDrive)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=http://localhost:3001/cloud/connect/onedrive/callback

# Public base URL (for share links and OAuth callbacks)
PUBLIC_BASE_URL=http://localhost:3001
